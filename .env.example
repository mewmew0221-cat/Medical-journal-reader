# Gemini（產摘要、翻譯標題）
GEMINI_API_KEY=

# NCBI（建議申請，速率 3→10 req/s）
NCBI_API_KEY=
NCBI_EMAIL=

# Google Sheet
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
SHEET_ID=

# 模型 routing（預設全 lite，摘要可升級）
# 摘要品質若不夠，把 SUMMARY_MODEL 改成 gemini-3.5-flash（穩定高品質）
LITE_MODEL=gemini-3.1-flash-lite
SUMMARY_MODEL=gemini-3.1-flash-lite
